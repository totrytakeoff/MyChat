# MyChat Benchmark 环境变量配置模板
# 复制此文件为 env.sh 并填入实际值: cp env.sh.example env.sh
# 注意: env.sh 不应提交到 git（已在 .gitignore 中）

# ---- 被测服务器 (SUT) ----
export BENCH_CLOUD_HOST="<cloud-server-ip>"
export BENCH_CLOUD_WSS_PORT=10001
export BENCH_CLOUD_HTTP_PORT=10002
export BENCH_CLOUD_SSH="<ssh-alias-or-user@host>"

# ---- 发压端 ----
export BENCH_PVE_HOST="<loadgen-ip>"
export BENCH_PVE_USER="root"
# 优先使用 SSH 密钥认证；仅在必须时设置密码
export BENCH_PVE_PASS=""

# ---- 测试用户 ----
export BENCH_USER_COUNT=200
export BENCH_USER_PASSWORD="pass1234"

# ---- 压测工具路径 (发压端) ----
export BENCH_PVE_TOOL_DIR="/tmp/benchmark"

# ---- 压测参数 ----
export BENCH_WSS_DURATION=60
export BENCH_WSS_INTERVAL_MS=5000
export BENCH_WSS_CONNECT_RATE=20
export BENCH_HTTP_VUS=10
export BENCH_HTTP_DURATION=60
